      "parameters": {
        "jsCode": "const idempotency_key = $('Normalize_Input').item.json.idempotency_key;\nconst basePath = `/tmp/qwrk-video/${idempotency_key}`;\n// Assume m4a for now (yt-dlp typically downloads as m4a for YouTube)\nconst audioFilePath = `${basePath}.m4a`;\n\nreturn {\n  audio_file_path: audioFilePath,\n  idempotency_key: idempotency_key\n};"
      },
