        "jsCode": "// Fallback chain for Supabase response shape variations\nconst artifact_id = $input.item.json.artifact_id\n  || $input.item.json.id\n  || ($input.item.json.data && $input.item.json.data[0] && $input.item.json.data[0].artifact_id)\n  || ($input.item.json.data && $input.item.json.data[0] && $input.item.json.data[0].id);\n\nif (!artifact_id) {\n  return {\n    ok: false,\n    error: {\n      stage: 'create_spine',\n      message: 'Failed to extract artifact_id from spine INSERT response'\n    }\n  };\n}\n\nreturn {\n  ok: true,\n  artifact_id: artifact_id\n};"
