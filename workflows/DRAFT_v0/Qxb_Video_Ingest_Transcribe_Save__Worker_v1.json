    {
      "parameters": {
        "jsCode": "// Validate required fields\nif (!$input.item.json.source_url || !$input.item.json.workspace_id || !$input.item.json.owner_user_id) {\n  return {\n    ok: false,\n    error: {\n      stage: 'normalize',\n      message: 'Missing required fields: source_url, workspace_id, owner_user_id'\n    }\n  };\n}\n\n// Normalize tags to array\nlet tags = ['video', 'youtube'];\nif ($input.item.json.tags) {\n  if (Array.isArray($input.item.json.tags)) {\n    tags = tags.concat($input.item.json.tags);\n  } else if (typeof $input.item.json.tags === 'string') {\n    tags = tags.concat($input.item.json.tags.split(',').map(t => t.trim()));\n  }\n}\n\n// Extract YouTube video_id (best effort)\nconst urlMatch = $input.item.json.source_url.match(/(?:youtube\\.com\\/watch\\?v=|youtu\\.be\\/)([^&?\\/]+)/);\nconst video_id = urlMatch ? urlMatch[1] : null;\n\n// Compute idempotency_key\nconst crypto = require('crypto');\nconst idempotency_key = video_id\n  ? `youtube:${video_id}`\n  : `youtube_url_hash:${crypto.createHash('sha256').update($input.item.json.source_url).digest('hex')}`;\n\n// Generate title if not provided\nconst title = $input.item.json.title_override || (video_id ? `Video: ${video_id}` : `Video: ${idempotency_key.slice(0, 16)}...`);\n\nreturn {\n  ok: true,\n  source_url: $input.item.json.source_url,\n  source_platform: 'youtube',\n  source_video_id: video_id,\n  workspace_id: $input.item.json.workspace_id,\n  owner_user_id: $input.item.json.owner_user_id,\n  title: title,\n  summary: $input.item.json.notes || 'Video transcript (ingested)',\n  tags: tags,\n  idempotency_key: idempotency_key\n};"
      },
