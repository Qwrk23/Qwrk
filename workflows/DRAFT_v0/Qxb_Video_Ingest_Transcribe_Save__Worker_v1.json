      "parameters": {
        "command": "mkdir -p /tmp/qwrk-video && yt-dlp -f 'bestaudio[ext=m4a]' --output '/tmp/qwrk-video/{{ $('Normalize_Input').item.json.idempotency_key }}.%(ext)s' --no-playlist --quiet '{{ $('Normalize_Input').item.json.source_url }}'"
