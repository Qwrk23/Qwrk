    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=<Response>\n  <Say voice=\"Polly.Joanna-Neural\">Great! How can I help you today?</Say>\n  <Gather input=\"speech\" timeout=\"5\" action=\"/webhook/twilio/voice/walk/handle?fname={{$node['Webhook'].json.query.fname}}&amp;lname={{$node['Webhook'].json.query.lname}}&amp;idstatus=confirmed&amp;email={{$node['Webhook'].json.query.email}}\" method=\"POST\">\n    <Say voice=\"Polly.Joanna-Neural\">Please briefly tell me what you need help with.</Say>\n  </Gather>\n  <Say voice=\"Polly.Joanna-Neural\">I didn't catch that. Please try calling again.</Say>\n</Response>",
